/* ============================================================================
   Kubernetes & Instance Management - Modern Redesign
   Clean, Minimalist, Vercel-inspired Design
   ============================================================================ */

/* ==================== Page Layout ==================== */
.page-container {
  min-height: 100vh;
  background: #09090b !important;
  padding: 24px 32px;
}

.kubernetes-page {
  max-width: 1600px;
  margin: 0 auto;
}

/* ==================== Page Header - Clean & Minimal ==================== */
.k8s-page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24px;
  padding: 20px 24px;
  background: transparent;
  border: none;
  backdrop-filter: none;
  box-shadow: none;
}

.k8s-page-header-left {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.k8s-page-title {
  display: flex;
  align-items: center;
  gap: 12px;
  margin: 0;
}

.k8s-page-title .anticon {
  font-size: 24px;
  color: #fafafa;
}

.k8s-page-title-text {
  font-size: 24px;
  font-weight: 600;
  color: #fafafa;
  letter-spacing: -0.02em;
  margin: 0;
}

.k8s-page-subtitle {
  font-size: 14px;
  color: #71717a;
  margin: 0;
}

.k8s-page-header-actions {
  display: flex;
  gap: 12px;
  align-items: center;
}

/* ==================== Stats Cards - Simple Grid ==================== */
.k8s-stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
  margin-bottom: 24px;
}

.stat-card-premium {
  background: #18181b;
  border: 1px solid #27272a;
  border-radius: 10px;
  padding: 20px;
  position: relative;
  overflow: hidden;
  transition: all 0.15s ease;
  box-shadow: none;
}

.stat-card-premium:hover {
  background: #1f1f23;
  border-color: #3f3f46;
  transform: none;
}

.stat-card-premium::before {
  display: none;
}

.stat-card-icon {
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8px;
  margin-bottom: 12px;
  font-size: 20px;
  background: #27272a;
  color: #a1a1aa;
}

.stat-card-icon.default {
  background: #27272a;
  color: #a1a1aa;
}

.stat-card-icon.success {
  background: rgba(16, 185, 129, 0.1);
  color: #34d399;
}

.stat-card-icon.warning {
  background: rgba(245, 158, 11, 0.1);
  color: #fbbf24;
}

.stat-card-premium:hover .stat-card-icon {
  transform: none;
}

.stat-card-label {
  font-size: 13px;
  color: #71717a;
  font-weight: 500;
  margin-bottom: 4px;
  text-transform: none;
  letter-spacing: normal;
  line-height: 1.4;
}

.stat-card-value {
  font-size: 32px;
  font-weight: 600;
  color: #fafafa;
  line-height: 1;
  letter-spacing: -0.02em;
  text-shadow: none;
}

.stat-card-subtitle {
  font-size: 12px;
  color: #52525b;
  margin-top: 4px;
  font-weight: 400;
}

.stat-card-trend {
  display: none;
}

/* ==================== Action Bar ==================== */
.k8s-action-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24px;
  padding: 12px 0;
  background: transparent;
  border: none;
  backdrop-filter: none;
}

.k8s-action-bar-left {
  display: flex;
  gap: 8px;
  align-items: center;
}

.k8s-action-bar-right {
  display: flex;
  gap: 8px;
  align-items: center;
}

/* ==================== Buttons - Clean & Simple ==================== */
.btn-premium-primary {
  background: #fafafa !important;
  border: none !important;
  color: #09090b !important;
  font-weight: 500 !important;
  padding: 8px 16px !important;
  border-radius: 8px !important;
  transition: all 0.15s ease !important;
  letter-spacing: normal;
}

.btn-premium-primary:hover {
  background: #e4e4e7 !important;
  transform: none !important;
  box-shadow: none !important;
}

.btn-premium-secondary {
  background: transparent !important;
  border: 1px solid #3f3f46 !important;
  color: #d4d4d8 !important;
  font-weight: 500 !important;
  padding: 8px 16px !important;
  border-radius: 8px !important;
  transition: all 0.15s ease !important;
  backdrop-filter: none;
}

.btn-premium-secondary:hover {
  background: #27272a !important;
  border-color: #52525b !important;
  color: #fafafa !important;
  transform: none !important;
  box-shadow: none !important;
}

/* ==================== Cluster Grid ==================== */
.cluster-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
  gap: 16px;
  margin-top: 24px;
}

/* ==================== Cluster Card - Clean Design ==================== */
.cluster-card-premium {
  background: #18181b;
  border: 1px solid #27272a;
  border-radius: 10px;
  overflow: hidden;
  transition: all 0.15s ease;
  position: relative;
}

.cluster-card-premium:hover {
  background: #1f1f23;
  border-color: #3f3f46;
  transform: none;
}

.cluster-card-premium::before {
  display: none;
}

.cluster-card-premium.connected {
  border-color: rgba(16, 185, 129, 0.2);
}

.cluster-card-premium.connected::after {
  display: none;
}

.cluster-card-header {
  padding: 20px;
  display: flex;
  align-items: flex-start;
  gap: 12px;
  position: relative;
  z-index: 1;
}

.cluster-card-icon {
  width: 48px;
  height: 48px;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #27272a;
  border-radius: 8px;
  color: #a1a1aa;
  font-size: 24px;
}

.cluster-card-icon.connected {
  background: rgba(16, 185, 129, 0.1);
  color: #34d399;
}

.cluster-card-icon.error {
  background: rgba(239, 68, 68, 0.1);
  color: #f87171;
}

.cluster-card-info {
  flex: 1;
  min-width: 0;
}

.cluster-card-name {
  font-size: 16px;
  font-weight: 600;
  color: #fafafa;
  margin-bottom: 4px;
  letter-spacing: -0.01em;
}

.cluster-card-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  align-items: center;
  margin-top: 6px;
}

.cluster-card-version {
  font-size: 12px;
  color: #71717a;
  background: #27272a;
  padding: 3px 8px;
  border-radius: 4px;
  font-weight: 500;
}

.cluster-card-actions {
  display: flex;
  gap: 6px;
  flex-shrink: 0;
}

.cluster-card-action-btn {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 6px;
  background: transparent;
  border: 1px solid #3f3f46;
  color: #71717a;
  transition: all 0.15s ease;
  cursor: pointer;
}

.cluster-card-action-btn:hover {
  background: #27272a;
  border-color: #52525b;
  color: #fafafa;
}

.cluster-card-action-btn.primary {
  color: #60a5fa;
  border-color: rgba(96, 165, 250, 0.2);
}

.cluster-card-action-btn.primary:hover {
  background: rgba(59, 130, 246, 0.1);
  border-color: rgba(59, 130, 246, 0.3);
}

.cluster-card-action-btn.danger {
  color: #f87171;
  border-color: rgba(248, 113, 113, 0.2);
}

.cluster-card-action-btn.danger:hover {
  background: rgba(239, 68, 68, 0.1);
  border-color: rgba(239, 68, 68, 0.3);
}

.cluster-card-body {
  padding: 0 20px 20px;
  position: relative;
  z-index: 1;
}

.cluster-card-status {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 12px;
  background: #27272a;
  border: 1px solid #3f3f46;
  border-radius: 8px;
  margin-bottom: 12px;
}

.cluster-card-status-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #52525b;
}

.cluster-card-status-dot.connected {
  background: #34d399;
}

.cluster-card-status-dot.error {
  background: #f87171;
}

.cluster-card-status-dot.warning {
  background: #fbbf24;
}

.cluster-card-status-text {
  font-size: 13px;
  font-weight: 500;
  color: #d4d4d8;
}

.cluster-card-status-label {
  font-size: 12px;
  color: #71717a;
  margin-left: auto;
}

.cluster-card-details {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}

.cluster-card-detail-item {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.cluster-card-detail-label {
  font-size: 11px;
  color: #71717a;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  font-weight: 500;
}

.cluster-card-detail-value {
  font-size: 13px;
  color: #d4d4d8;
  font-weight: 500;
  word-break: break-all;
}

/* ==================== Empty State ==================== */
.k8s-empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80px 24px;
  text-align: center;
}

.k8s-empty-state-icon {
  width: 120px;
  height: 120px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.15) 0%, rgba(139, 92, 246, 0.1) 100%);
  border-radius: 60px;
  margin-bottom: 24px;
  color: rgba(59, 130, 246, 0.4);
  font-size: 56px;
}

.k8s-empty-state-title {
  font-size: 20px;
  font-weight: 600;
  color: #F9FAFB;
  margin-bottom: 8px;
}

.k8s-empty-state-description {
  font-size: 15px;
  color: #9CA3AF;
  margin-bottom: 32px;
  max-width: 400px;
}

/* ==================== Drawer Enhancements ==================== */
.ant-drawer-content {
  background: #111827 !important;
  border: none !important;
}

.ant-drawer-header {
  background: linear-gradient(135deg, rgba(31, 41, 55, 0.95) 0%, rgba(17, 24, 39, 0.98) 100%) !important;
  border-bottom: 1px solid rgba(75, 85, 99, 0.2) !important;
  padding: 20px 24px !important;
}

.ant-drawer-title {
  color: #F9FAFB !important;
  font-size: 18px;
  font-weight: 700;
}

.ant-drawer-body {
  padding: 24px !important;
}

/* ==================== Table Enhancements ==================== */
.ant-table {
  background: transparent !important;
}

.ant-table-thead > tr > th {
  background: rgba(31, 41, 55, 0.8) !important;
  color: #F9FAFB !important;
  font-weight: 600 !important;
  font-size: 13px !important;
  text-transform: uppercase !important;
  letter-spacing: 0.5px !important;
  border-bottom: 1px solid rgba(75, 85, 99, 0.3) !important;
  padding: 14px 16px !important;
}

.ant-table-tbody > tr > td {
  background: transparent !important;
  color: #E5E7EB !important;
  border-bottom: 1px solid rgba(75, 85, 99, 0.15) !important;
  padding: 16px !important;
  font-size: 14px !important;
}

.ant-table-tbody > tr:hover > td {
  background: rgba(31, 41, 55, 0.4) !important;
}

.ant-table-row-expand-icon {
  background: rgba(31, 41, 55, 0.8) !important;
  border-color: rgba(75, 85, 99, 0.3) !important;
  color: #9CA3AF !important;
  border-radius: 6px !important;
}

.ant-table-row-expand-icon:hover {
  color: #60A5FA !important;
  border-color: rgba(59, 130, 246, 0.5) !important;
}

/* ==================== Tag Enhancements ==================== */
.ant-tag {
  border-radius: 8px !important;
  font-weight: 600 !important;
  font-size: 12px !important;
  padding: 4px 12px !important;
  border-width: 1px !important;
}

.ant-tag-green {
  background: rgba(16, 185, 129, 0.15) !important;
  border-color: rgba(16, 185, 129, 0.3) !important;
  color: #34D399 !important;
}

.ant-tag-blue {
  background: rgba(59, 130, 246, 0.15) !important;
  border-color: rgba(59, 130, 246, 0.3) !important;
  color: #60A5FA !important;
}

.ant-tag-purple {
  background: rgba(139, 92, 246, 0.15) !important;
  border-color: rgba(139, 92, 246, 0.3) !important;
  color: #A78BFA !important;
}

/* ==================== Modal Enhancements ==================== */
.kubernetes-page .ant-modal-content,
body .ant-modal-content {
  background: linear-gradient(135deg, rgba(31, 41, 55, 0.98) 0%, rgba(17, 24, 39, 0.98) 100%) !important;
  border: 1px solid rgba(75, 85, 99, 0.3) !important;
  border-radius: 16px !important;
  box-shadow: 0 24px 64px rgba(0, 0, 0, 0.6) !important;
}

.kubernetes-page .ant-modal-header,
body .ant-modal-header {
  background: linear-gradient(135deg, rgba(31, 41, 55, 0.95) 0%, rgba(17, 24, 39, 0.95) 100%) !important;
  border-bottom: 1px solid rgba(75, 85, 99, 0.2) !important;
  border-radius: 16px 16px 0 0 !important;
  padding: 20px 24px !important;
}

.kubernetes-page .ant-modal-title,
body .ant-modal-title {
  color: #F9FAFB !important;
  font-size: 18px !important;
  font-weight: 700 !important;
}

.kubernetes-page .ant-modal-body,
body .ant-modal-body {
  padding: 24px !important;
  color: #E5E7EB !important;
}

.kubernetes-page .ant-modal-footer,
body .ant-modal-footer {
  border-top: 1px solid rgba(75, 85, 99, 0.2) !important;
  background: linear-gradient(135deg, rgba(31, 41, 55, 0.95) 0%, rgba(17, 24, 39, 0.95) 100%) !important;
  padding: 16px 24px !important;
  border-radius: 0 0 16px 16px !important;
}

.kubernetes-page .ant-modal-close,
body .ant-modal-close {
  color: #9CA3AF !important;
}

.kubernetes-page .ant-modal-close:hover,
body .ant-modal-close:hover {
  color: #F9FAFB !important;
}

/* Modal Input Styling - Ant Design v6 compatible */
.kubernetes-page .ant-modal .ant-input,
.kubernetes-page .ant-modal .ant-input-number,
.kubernetes-page .ant-modal .ant-select-content,
body .ant-modal .ant-input,
body .ant-modal .ant-input-number,
body .ant-modal .ant-select-content {
  background: rgba(15, 23, 42, 0.98) !important;
  border-color: rgba(75, 85, 99, 0.3) !important;
  color: #F9FAFB !important;
}

.kubernetes-page .ant-modal .ant-input::placeholder,
body .ant-modal .ant-input::placeholder {
  color: #6B7280 !important;
}

/* ==================== Progress Bar ==================== */
.ant-progress-bg {
  background: linear-gradient(90deg, #3B82F6 0%, #8B5CF6 100%) !important;
  border-radius: 4px !important;
}

.ant-progress-bg-status-success {
  background: linear-gradient(90deg, #10B981 0%, #34D399 100%) !important;
}

/* ==================== Select Dropdown - Conservative Fix ==================== */
/* Only fix critical issues, avoid over-engineering */
.ant-select-dropdown {
  background: rgba(30, 41, 59, 0.95) !important;
  border: 1px solid rgba(148, 163, 184, 0.2) !important;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4) !important;
}

.ant-select-item {
  color: #f1f5f9 !important;
}

.ant-select-item:hover {
  background: rgba(59, 130, 246, 0.15) !important;
}

.ant-select-item-option-selected {
  background: rgba(59, 130, 246, 0.15) !important;
  color: #60a5fa !important;
}

.namespace-select .ant-select-arrow {
  color: #fbbf24 !important;
  font-size: 18px !important;
}

/* ==================== Responsive ==================== */
@media (max-width: 1400px) {
  .k8s-stats-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  
  .cluster-grid {
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
  }
}

@media (max-width: 768px) {
  .k8s-page-wrapper {
    padding: 16px 20px;
  }
  
  .k8s-page-header {
    flex-direction: column;
    gap: 20px;
  }
  
  .k8s-stats-grid {
    grid-template-columns: 1fr;
  }
  
  .cluster-grid {
    grid-template-columns: 1fr;
  }
  
  .k8s-action-bar {
    flex-direction: column;
    gap: 16px;
    align-items: stretch;
  }
  
  .k8s-action-bar-left,
  .k8s-action-bar-right {
    justify-content: center;
  }
}

/* ==================== Animations ==================== */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.cluster-card-premium,
.stat-card-premium {
  animation: fadeInUp 0.5s ease-out;
}

@keyframes pulse {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.5;
  }
}

.cluster-card-status-dot.connected {
  animation: pulse 2s ease-in-out infinite;
}

/* ==================== Compact Cluster Card ==================== */
.cluster-card-status-dot-inline {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  display: inline-block;
  margin-left: 10px;
  vertical-align: middle;
}

.cluster-card-status-dot-inline.connected {
  background: #10B981;
  box-shadow: 0 0 12px rgba(16, 185, 129, 0.5);
}

.cluster-card-status-dot-inline.error {
  background: #F87171;
  box-shadow: 0 0 12px rgba(248, 113, 113, 0.5);
}

.cluster-card-status-dot-inline.warning {
  background: #FBBF24;
  box-shadow: 0 0 12px rgba(251, 191, 36, 0.5);
}

.cluster-card-divider {
  color: #4B5563;
  margin: 0 4px;
}

.cluster-card-stats {
  font-size: 13px;
  color: #9CA3AF;
  display: inline-flex;
  align-items: center;
}

/* ==================== Loading State ==================== */
.k8s-loading-container {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 400px;
}

.k8s-loading-spinner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16px;
}

.k8s-loading-spinner .ant-spin {
  color: #3B82F6 !important;
}

.k8s-loading-text {
  font-size: 14px;
  color: #9CA3AF;
}

/* ==================== Remove White Outline from Modal ==================== */
/* Fix Ant Design 6.x default focus outline */
.kubernetes-page .ant-modal-container,
.kubernetes-page .ant-modal,
body .ant-modal-container,
body .ant-modal {
  outline: none !important;
  outline-color: transparent !important;
  outline-width: 0 !important;
}

.kubernetes-page .ant-modal-container:focus,
.kubernetes-page .ant-modal:focus,
.kubernetes-page .ant-modal-container:focus-visible,
.kubernetes-page .ant-modal:focus-visible,
body .ant-modal-container:focus,
body .ant-modal:focus,
body .ant-modal-container:focus-visible,
body .ant-modal:focus-visible {
  outline: none !important;
}
