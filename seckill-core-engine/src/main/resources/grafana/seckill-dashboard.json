{
  "dashboard": {
    "title": "Seckill Core Engine - Monitoring Dashboard",
    "uid": "seckill-core-engine",
    "tags": ["seckill", "high-concurrency", "prometheus"],
    "timezone": "browser",
    "refresh": "10s",
    "schemaVersion": 16,
    "version": 0,
    "panels": [
      {
        "id": 1,
        "title": "秒杀请求总览",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "rate(seckill_request_total[1m])",
            "legendFormat": "QPS",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "reduceOptions": {"calcs": ["lastNotNull"]}
        },
        "fieldConfig": {
          "defaults": {
            "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 1000}, {"color": "red", "value": 5000}]},
            "unit": "req/s"
          }
        }
      },
      {
        "id": 2,
        "title": "秒杀成功率",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
        "targets": [
          {
            "expr": "rate(seckill_success_total[1m]) / rate(seckill_request_total[1m]) * 100",
            "legendFormat": "成功率",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "reduceOptions": {"calcs": ["lastNotNull"]}
        },
        "fieldConfig": {
          "defaults": {
            "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": 0}, {"color": "yellow", "value": 80}, {"color": "green", "value": 95}]},
            "unit": "percent"
          }
        }
      },
      {
        "id": 3,
        "title": "库存不足率",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "rate(seckill_stock_insufficient_total[1m]) / rate(seckill_request_total[1m]) * 100",
            "legendFormat": "库存不足率",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "reduceOptions": {"calcs": ["lastNotNull"]}
        },
        "fieldConfig": {
          "defaults": {
            "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 10}, {"color": "red", "value": 30}]},
            "unit": "percent"
          }
        }
      },
      {
        "id": 4,
        "title": "重复购买率",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
        "targets": [
          {
            "expr": "rate(seckill_already_bought_total[1m]) / rate(seckill_request_total[1m]) * 100",
            "legendFormat": "重复购买率",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "reduceOptions": {"calcs": ["lastNotNull"]}
        },
        "fieldConfig": {
          "defaults": {
            "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 5}, {"color": "red", "value": 15}]},
            "unit": "percent"
          }
        }
      },
      {
        "id": 5,
        "title": "秒杀请求趋势",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
        "targets": [
          {
            "expr": "rate(seckill_request_total[1m])",
            "legendFormat": "请求QPS",
            "refId": "A"
          },
          {
            "expr": "rate(seckill_success_total[1m])",
            "legendFormat": "成功QPS",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {"custom": {"lineWidth": 2, "fillOpacity": 10}, "unit": "req/s"}
        }
      },
      {
        "id": 6,
        "title": "失败原因分布",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
        "targets": [
          {
            "expr": "rate(seckill_stock_insufficient_total[1m])",
            "legendFormat": "库存不足",
            "refId": "A"
          },
          {
            "expr": "rate(seckill_already_bought_total[1m])",
            "legendFormat": "重复购买",
            "refId": "B"
          },
          {
            "expr": "rate(seckill_stock_not_warmed_total[1m])",
            "legendFormat": "库存未预热",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {"custom": {"lineWidth": 2, "fillOpacity": 10}, "unit": "req/s"}
        }
      },
      {
        "id": 7,
        "title": "Lua脚本执行耗时",
        "type": "timeseries",
        "gridPos": {"h": 6, "w": 12, "x": 0, "y": 12},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(seckill_lua_seconds_bucket[1m]))",
            "legendFormat": "P50",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, rate(seckill_lua_seconds_bucket[1m]))",
            "legendFormat": "P95",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.99, rate(seckill_lua_seconds_bucket[1m]))",
            "legendFormat": "P99",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {"custom": {"lineWidth": 2, "fillOpacity": 10}, "unit": "s"}
        }
      },
      {
        "id": 8,
        "title": "订单创建耗时",
        "type": "timeseries",
        "gridPos": {"h": 6, "w": 12, "x": 12, "y": 12},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(seckill_order_create_seconds_bucket[1m]))",
            "legendFormat": "P50",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, rate(seckill_order_create_seconds_bucket[1m]))",
            "legendFormat": "P95",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.99, rate(seckill_order_create_seconds_bucket[1m]))",
            "legendFormat": "P99",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {"custom": {"lineWidth": 2, "fillOpacity": 10}, "unit": "s"}
        }
      },
      {
        "id": 9,
        "title": "Redis状态",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 0, "y": 18},
        "targets": [
          {
            "expr": "seckill_redis_status",
            "legendFormat": "状态",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "background",
          "reduceOptions": {"calcs": ["lastNotNull"]}
        },
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {"type": "value", "options": {"0": {"text": "正常", "color": "green"}, "1": {"text": "降级", "color": "yellow"}, "2": {"text": "故障", "color": "red"}}}
            ]
          }
        }
      },
      {
        "id": 10,
        "title": "MQ状态",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 4, "y": 18},
        "targets": [
          {
            "expr": "seckill_mq_status",
            "legendFormat": "状态",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "background",
          "reduceOptions": {"calcs": ["lastNotNull"]}
        },
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {"type": "value", "options": {"0": {"text": "正常", "color": "green"}, "1": {"text": "降级", "color": "yellow"}, "2": {"text": "故障", "color": "red"}}}
            ]
          }
        }
      },
      {
        "id": 11,
        "title": "库存预热状态",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 8, "y": 18},
        "targets": [
          {
            "expr": "seckill_warmup_status",
            "legendFormat": "状态",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "background",
          "reduceOptions": {"calcs": ["lastNotNull"]}
        },
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {"type": "value", "options": {"0": {"text": "未预热", "color": "yellow"}, "1": {"text": "已预热", "color": "green"}}}
            ]
          }
        }
      },
      {
        "id": 12,
        "title": "事务消息状态",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 12, "y": 18},
        "targets": [
          {
            "expr": "rate(seckill_transaction_success_total[1m])",
            "legendFormat": "成功",
            "refId": "A"
          },
          {
            "expr": "rate(seckill_transaction_failed_total[1m])",
            "legendFormat": "失败",
            "refId": "B"
          }
        ],
        "options": {
          "colorMode": "value",
          "reduceOptions": {"calcs": ["lastNotNull"]}
        },
        "fieldConfig": {
          "defaults": {"unit": "req/s"}
        }
      },
      {
        "id": 13,
        "title": "库存对账差异",
        "type": "timeseries",
        "gridPos": {"h": 6, "w": 12, "x": 0, "y": 22},
        "targets": [
          {
            "expr": "seckill_stock_redis_count{seckill_id=~\"$seckill_id\"}",
            "legendFormat": "Redis库存",
            "refId": "A"
          },
          {
            "expr": "seckill_stock_mysql_count{seckill_id=~\"$seckill_id\"}",
            "legendFormat": "MySQL库存",
            "refId": "B"
          },
          {
            "expr": "abs(seckill_stock_redis_count{seckill_id=~\"$seckill_id\"} - seckill_stock_mysql_count{seckill_id=~\"$seckill_id\"})",
            "legendFormat": "差异",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {"custom": {"lineWidth": 2, "fillOpacity": 10}, "unit": "short"}
        }
      },
      {
        "id": 14,
        "title": "JVM内存使用",
        "type": "timeseries",
        "gridPos": {"h": 6, "w": 12, "x": 12, "y": 22},
        "targets": [
          {
            "expr": "jvm_memory_used_bytes{area=\"heap\"}",
            "legendFormat": "Heap Used",
            "refId": "A"
          },
          {
            "expr": "jvm_memory_max_bytes{area=\"heap\"}",
            "legendFormat": "Heap Max",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {"custom": {"lineWidth": 2, "fillOpacity": 10}, "unit": "bytes"}
        }
      }
    ],
    "templating": {
      "list": [
        {
          "name": "seckill_id",
          "type": "query",
          "query": "label_values(seckill_stock_redis_count, seckill_id)",
          "refresh": 1,
          "includeAll": true,
          "allValue": ".+",
          "multi": true
        }
      ]
    }
  },
  "overwrite": true
}